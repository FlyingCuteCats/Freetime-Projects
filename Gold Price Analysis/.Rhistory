mean_from_range("(300-325)")
gsub("[^0-9-]", "", "(300-325)")
?gsub
gsub("[^(\d+)-]", "", "(300-325)")
gsub("[^0-9+-]", "", "(300-325)")
gsub("[^0-9+-0-9+]", "", "(300-325)")
gsub("[^0-9+\-0-9+]", "", "(300-325)")
gsub("[^0-9-]", "", "(300-325)")
gsub("0-9[2]", "0",gsub("[^0-9-]", "", "(300-325)"))
gsub("0-9[2]-", ".%",gsub("[^0-9-]", "", "(300-325)"))
